{
  "name": "seizn",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for Seizn AI Memory",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "memory",
    "llm",
    "rag",
    "vector",
    "embeddings",
    "langchain",
    "openai",
    "anthropic"
  ],
  "author": "Seizn <support@seizn.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seizn/seizn-js.git"
  },
  "homepage": "https://seizn.com",
  "bugs": {
    "url": "https://github.com/seizn/seizn-js/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
