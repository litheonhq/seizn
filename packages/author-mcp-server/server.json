{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.litheonhq/author-mcp-server",
  "description": "Recall, check, search, timeline, and graph tools for fiction writers via Seizn Memory v3.",
  "repository": {
    "url": "https://github.com/litheonhq/seizn",
    "source": "github",
    "subfolder": "packages/author-mcp-server"
  },
  "version": "0.1.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@seizn/author-mcp-server",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "SEIZN_API_KEY",
          "description": "Bearer token from https://seizn.com/dashboard/account/api-keys",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "SEIZN_API_BASE_URL",
          "description": "Override the API base URL (default: https://seizn.com/api/v1)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
