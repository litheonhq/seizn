{
  "name": "@seizn/personas-kr",
  "version": "0.1.0-beta.1",
  "description": "Bundled Korean synthetic persona sample loader for Seizn NPC seeding.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "data",
    "LICENSE",
    "LICENSE.dataset",
    "ATTRIBUTION.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "keywords": [
    "seizn",
    "personas",
    "korean",
    "nemotron",
    "npc"
  ],
  "author": "Seizn <support@seizn.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/litheonhq/seizn.git",
    "directory": "packages/seizn-personas-kr"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
