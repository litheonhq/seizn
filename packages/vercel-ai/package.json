{
  "name": "@seizn/vercel-ai",
  "version": "0.1.0",
  "description": "Vercel AI SDK adapter for Seizn AI Infrastructure - RAG tools, middleware, and providers",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.mjs",
      "require": "./dist/tools.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.mjs",
      "require": "./dist/middleware.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.mjs",
      "require": "./dist/provider.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/tools.ts src/middleware.ts src/provider.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/tools.ts src/middleware.ts src/provider.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "seizn",
    "vercel",
    "ai-sdk",
    "rag",
    "retrieval",
    "llm",
    "tools",
    "middleware",
    "provider",
    "openai",
    "anthropic",
    "citations"
  ],
  "author": "Seizn <support@seizn.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seizn/seizn-sdk.git",
    "directory": "packages/vercel-ai"
  },
  "homepage": "https://seizn.com/docs/sdk/vercel-ai",
  "bugs": {
    "url": "https://github.com/seizn/seizn-sdk/issues"
  },
  "peerDependencies": {
    "ai": ">=3.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": false
    },
    "zod": {
      "optional": false
    }
  },
  "dependencies": {
    "@seizn/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ai": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
