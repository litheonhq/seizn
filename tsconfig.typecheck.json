{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "src/types/**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    ".next/dev",
    "mcp-server",
    "examples",
    "packages",
    "cli",
    "relay-agent",
    "scripts",
    "src/test",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
