# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local
__pycache__/

# SDKs build artifacts
sdks/*/node_modules/
sdks/*/dist/
sdks/*/*.egg-info/
sdks/*/package-lock.json
packages/*/node_modules/
packages/*/dist/
cli/*/node_modules/
cli/*/dist/

# CI artifacts
.seizn-traces/
.seizn-generated-tests/

# Supabase local runtime and generated SQL artifacts
/supabase/.temp/
/supabase/all_migrations.sql
/supabase/batches/
