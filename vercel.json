{
  "ignoreCommand": "npm run vercel:ignore-build",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "regions": [
    "hnd1"
  ],
  "functions": {
    "src/app/api/v1/memories/route.ts": { "maxDuration": 90 },
    "src/app/api/memories/route.ts": { "maxDuration": 90 },
    "src/app/api/spring/search-v3/route.ts": { "maxDuration": 90 },
    "src/app/api/memories/search_v4/route.ts": { "maxDuration": 90 }
  },
  "redirects": [
    {
      "source": "/((?!api/webhooks/).*)",
      "has": [
        {
          "type": "host",
          "value": "seizn.com"
        }
      ],
      "destination": "https://www.seizn.com/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/subscription-expiry",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/monthly-reset",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/internal/usage/flush",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/internal/webhooks",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/dsr-worker",
      "schedule": "0 * * * *"
    }
  ]
}
