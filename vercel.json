{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "seizn.com"
        }
      ],
      "destination": "https://www.seizn.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/internal/optimize",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/internal/webhooks",
      "schedule": "* * * * *"
    }
  ]
}
