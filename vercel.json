{
  "ignoreCommand": "npm run vercel:ignore-build",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "regions": [
    "hnd1"
  ],
  "functions": {
    "src/app/api/v1/memories/route.ts": { "maxDuration": 90 },
    "src/app/api/memories/route.ts": { "maxDuration": 90 },
    "src/app/api/spring/search-v3/route.ts": { "maxDuration": 90 },
    "src/app/api/memories/search_v4/route.ts": { "maxDuration": 90 }
  },
  "redirects": [
    {
      "source": "/((?!api/webhooks/).*)",
      "has": [
        {
          "type": "host",
          "value": "seizn.com"
        }
      ],
      "destination": "https://www.seizn.com/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/internal/optimize",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/internal/webhooks",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/internal/usage/flush",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/internal/chaos/worker",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/internal/story-health/evaluate",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/usage-alerts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/drift-analysis",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/subscription-expiry",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/monthly-reset",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/usage-cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/internal/eval-processor",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/audit-batch",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/dsr-worker",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/tier-demotion",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/mrr-snapshot",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/continuity-reports",
      "schedule": "0 2 * * *"
    }
  ]
}
