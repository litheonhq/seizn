            "assigned_characters": ["string"],
            "new_scope": "string?",
            "new_tier": "string?",
            "valid_at": "ISO8601?",
            "invalid_at": "ISO8601?"
          }
        },
        "response": {
          "candidate_id": "string",
          "new_status": "string",
          "promoted_entity_id": "string?",
          "side_effects": [
            {"type": "graph_updated|memory_added|conflict_detected", "details": "object"}
          ]
