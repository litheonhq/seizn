# Seizn Environment Variables Template
# Copy this to .env.local and fill in values

# ===================
# Supabase
# ===================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Database
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ===================
# Redis (Upstash)
# ===================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===================
# AI APIs
# ===================
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# ===================
# Auth (NextAuth)
# ===================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AUTH_COOKIE_DOMAIN=

# ===================
# Payment (Paddle)
# ===================
# Get from Paddle Dashboard > Developer Tools > Authentication
# Client-side token (public, used in browser for checkout overlay)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Environment: sandbox (for testing) or production (for live payments)
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
# Server-side API key (for webhooks and API calls - keep secret!)
PADDLE_API_KEY=
# Webhook secret for verifying Paddle webhook signatures
PADDLE_WEBHOOK_SECRET=

# ===================
# Payment (Stripe) — alternative to Paddle
# ===================
STRIPE_WEBHOOK_SECRET=

# ===================
# Email (Resend)
# ===================
RESEND_API_KEY=

# ===================
# AI APIs (additional providers)
# ===================
OPENAI_API_KEY=
COHERE_API_KEY=
GOOGLE_AI_API_KEY=

# ===================
# Security
# ===================
# Cloudflare Turnstile for bot protection
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# BYOK encryption
BYOK_ENCRYPTION_SALT=
BYOK_ENCRYPTION_SECRET=
SEIZN_ENCRYPTION_KEY=

# ===================
# Alerts (optional)
# ===================
SLACK_WEBHOOK_URL=
ALERT_EMAIL=

# ===================
# Analytics (optional)
# ===================
POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===================
# Sentry (Error Monitoring)
# ===================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source maps upload (get from https://sentry.io/settings/auth-tokens/)
SENTRY_AUTH_TOKEN=

# ===================
# BYO Vector Store (Bring Your Own)
# ===================
# Choose provider: pinecone, weaviate, qdrant
# Leave empty to use default Supabase pgvector
VECTOR_STORE_PROVIDER=

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_NAMESPACE=

# --- Weaviate ---
WEAVIATE_HOST=
WEAVIATE_API_KEY=
WEAVIATE_SCHEME=https
WEAVIATE_CLASS_NAME=
WEAVIATE_TENANT=

# --- Qdrant ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=

# ===================
# Cron Jobs
# ===================
# Secret for authenticating Vercel cron jobs
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ===================
# OpenTelemetry (OTEL) Export
# ===================
# Enable OTEL trace export to external observability tools (Jaeger, Datadog, Grafana, etc.)
# Set to 'true' to enable export
OTEL_EXPORTER_ENABLED=false
# OTLP endpoint URL (default: http://localhost:4318/v1/traces for Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Service name in traces
OTEL_SERVICE_NAME=seizn
# Service version (optional)
OTEL_SERVICE_VERSION=
# Environment name (development, staging, production)
OTEL_ENVIRONMENT=development
# Custom headers for OTLP requests (format: key1=value1,key2=value2)
# Example for Datadog: dd-api-key=your-api-key
OTEL_EXPORTER_OTLP_HEADERS=
# Batch export interval in milliseconds (default: 5000)
OTEL_BATCH_INTERVAL=5000
# Maximum batch size (default: 512)
OTEL_MAX_BATCH_SIZE=512
# Export timeout in milliseconds (default: 30000)
OTEL_EXPORT_TIMEOUT=30000
# Enable debug logging for OTEL
OTEL_DEBUG=false

# ===================
# PII Detection (Presidio - optional)
# ===================
PRESIDIO_ANALYZER_URL=
PRESIDIO_ANONYMIZER_URL=

# ===================
# App Configuration
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
