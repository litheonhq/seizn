{
  "name": "seizn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "check:policy": "node scripts/policy-consistency-check.mjs",
    "build": "node scripts/check-route-conflicts.js && next build",
    "analyze": "node scripts/analyze-build.mjs",
    "analyze:budget": "npm run analyze && node scripts/check-bundle-budget.mjs",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "start": "next start",
    "lint": "eslint . --ignore-pattern test-results --ignore-pattern playwright-report",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "predeploy": "bash scripts/pre-deploy.sh",
    "deploy": "vercel --prod",
    "smoke:production": "node scripts/production-smoke.mjs",
    "check:routes": "node scripts/check-route-conflicts.js",
    "generate:docs": "npx ts-node --project tsconfig.node.json scripts/generate-docs.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run src/__tests__/security/llm-top10/",
    "test:security:strict": "node scripts/run-security-strict.mjs",
    "verify:evidence": "npx ts-node --project tsconfig.node.json scripts/verify-evidence-pack.ts",
    "verify:e2e-encryption-db": "node scripts/db-verify-e2e-encryption.mjs",
    "verify:runtime-primitives": "node scripts/db-verify-runtime-primitives.mjs",
    "verify:ai-os-memory": "node scripts/verify-ai-os-memory.mjs",
    "vercel:ignore-build": "node scripts/vercel-ignore-build.mjs",
    "refresh:competitive-research": "node scripts/market/update-competitive-research.mjs",
    "security:red-team": "npx ts-node --project tsconfig.node.json scripts/red-team-ci.ts"
  },
