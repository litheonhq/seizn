{
  "name": "seizn",
  "version": "0.1.0",
  "description": "Seizn - AI Memory Infrastructure for Developers",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "memory",
    "llm",
    "rag",
    "embeddings",
    "vector-search",
    "claude",
    "openai",
    "semantic-search"
  ],
  "author": "Seizn Team <support@seizn.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seizn/seizn-js.git"
  },
  "homepage": "https://seizn.dev",
  "bugs": {
    "url": "https://github.com/seizn/seizn-js/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
